# .env.example
# 业财一体化API环境变量配置

# 应用配置
NODE_ENV=development
PORT=3000

# 数据库配置
DATABASE_URL="file:./dev.db"
# 生产环境使用PostgreSQL:
# DATABASE_URL="postgresql://user:password@localhost:5432/yewu_prod"

# AI服务配置
# DeepSeek LLM (推荐)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
# 或使用OpenAI:
# OPENAI_API_KEY=sk-your-openai-api-key
# 或使用MiniMax:
# MINIMAX_API_KEY=your-minimax-api-key

# 日志配置
LOG_LEVEL=info

# SFTP配置（文件监控）
SFTP_HOST=sftp.example.com
SFTP_PORT=22
SFTP_USER=your-username
SFTP_PASSWORD=your-password
SFTP_WATCH_DIR=/data/reconciliation

# 安全配置
API_RATE_LIMIT=100
API_RATE_WINDOW=60000
